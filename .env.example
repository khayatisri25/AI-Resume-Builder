# App Configuration
PORT=8000
DEBUG=True

# Database Configuration
# SQLite is used by default. Leave empty to use default path.
DATABASE_URL=sqlite:///database/resume_builder.db

# AI Model Configuration
# Available options for DEFAULT_LLM_PROVIDER: "gemini", "openai", "mock"
DEFAULT_LLM_PROVIDER=gemini

# Google Gemini Configuration
# Obtain keys from Google AI Studio: https://aistudio.google.com
GEMINI_API_KEY=

# OpenAI Configuration (Optional Swappable Provider)
OPENAI_API_KEY=

# Model details
DEFAULT_GEMINI_MODEL=gemini-2.5-flash
DEFAULT_OPENAI_MODEL=gpt-4o-mini
